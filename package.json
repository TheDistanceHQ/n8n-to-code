{
  "name": "n8n-to-code",
  "version": "0.1.0",
  "private": true,
  "description": "Convert n8n workflows to compiled TypeScript",
  "workspaces": [
    "packages/types",
    "packages/context-shim",
    "packages/compiler",
    "packages/executor",
    "packages/cli"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "rm -rf packages/*/dist",
    "typecheck": "tsc --build",
    "test": "jest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^25.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.9.3"
  }
}
